# Local development environment — copy to .env and adjust
# All vars use FORGE_ prefix (see forge.core.settings)

# Storage: point at local GCS emulator when developing on Mac
FORGE_STORAGE_EMULATOR_HOST=http://localhost:4443
FORGE_GCS_PROJECT=forge-local
FORGE_GCS_BUCKET_DATA=forge-data
FORGE_GCS_BUCKET_CHECKPOINTS=forge-checkpoints
FORGE_GCS_BUCKET_ARTIFACTS=forge-artifacts

# GCP project (used in Terraform and Workload Identity)
FORGE_GCP_PROJECT_ID=your-gcp-project-id

# Logging
FORGE_LOG_LEVEL=DEBUG

# W&B: disable locally unless you have a key
FORGE_WANDB_ENABLED=false
# FORGE_WANDB_PROJECT=gcp-diffusion-forge

# Prefect: local server started via docker-compose
# FORGE_PREFECT_API_URL=http://localhost:4200/api
